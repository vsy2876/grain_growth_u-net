# 2D Grain Growth Simulation
seed ${mySeed}

# Variables
variable kT equal ${myTemp}
variable N equal 512
variable Q equal 2048

# Setup application
app_style potts/neighonly ${Q}
dimension 2
lattice sq/8n 1.0

# Create simulation box
region box block 0 ${N} 0 ${N} -0.5 0.5
create_box box
create_sites box

# Initialize random grain orientations
set i1 range 1 ${Q}

# Set temperature
temperature ${kT}

# Configure solver
solve_style tree
sector yes

# PRE-COARSENING PHASE: Run without dumping to create larger grains
#stats 10.0
run 2000.0

# Save initial coarsened state (Sorted for Python Reshaping)
dump 1 text 1.0 initial_grains.dump id i1
dump_modify 1 sort id
run 0.0
undump 1

# NOW start your main simulation with fewer, larger grains
# (Sorted for Python Reshaping)
dump 2 text 100.0 grain_growth.dump id i1
dump_modify 2 sort id
#stats 50.0
run 1000.0
